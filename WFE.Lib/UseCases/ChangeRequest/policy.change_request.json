{
  "policy_name": "projectchangerequest.policy",
  "defName": "ProjectChangeRequest",
  "params": [
    { "code": "PARAMS.CHANGE.STEERING.APPROVAL", "data": { "approval": { "rule": "any", "selector": { "mode": "role", "value": "steering_committee" } } } }
  ],
  "rules": [
    {
      "state": "ImpactAssessment",
      "emit": [
        { "route": "APP.CHANGE.IMPACT.ASSESS", "label": "Impact Assessment", "group": "impact_decision", "order": 1, "complete": { "success": 4001, "failure": 4002 }, "type": "gate" },
        { "route": "APP.CHANGE.IMPACT.AUDIT.LOG", "label": "Impact Audit Log", "type": "effect" },
        { "route": "APP.CHANGE.IMPACT.NOTIFY.REQUESTOR", "label": "Impact Decision Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "CostReview",
      "emit": [
        { "route": "APP.CHANGE.COST.REVIEW", "label": "Cost Review", "group": "cost_decision", "order": 1, "complete": { "success": 4003, "failure": 4004 }, "type": "gate" },
        { "route": "APP.CHANGE.COST.LOCAL.BACKUP", "label": "Cost Snapshot Backup", "type": "effect" },
        { "route": "APP.CHANGE.COST.EMAIL.STAKEHOLDERS", "label": "Cost Decision Email", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "ScheduleReview",
      "emit": [
        { "route": "APP.CHANGE.SCHEDULE.REVIEW", "label": "Schedule Review", "group": "schedule_decision", "order": 1, "complete": { "success": 4005, "failure": 4006 }, "type": "gate" },
        { "route": "APP.CHANGE.SCHEDULE.AUDIT.LOG", "label": "Schedule Audit Log", "type": "effect" },
        { "route": "APP.CHANGE.SCHEDULE.CALENDAR.UPDATE", "label": "Project Calendar Update", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "SteeringDecision",
      "params": [ "PARAMS.CHANGE.STEERING.APPROVAL" ],
      "emit": [
        { "route": "APP.CHANGE.STEERING.DECIDE", "label": "Steering Decision", "group": "steering_decision", "order": 1, "complete": { "success": 4007, "failure": 4008 }, "type": "gate" },
        { "route": "APP.CHANGE.STEERING.MINUTES.ARCHIVE", "label": "Steering Minutes Archive", "order": 2, "type": "gate" },
        { "route": "APP.CHANGE.STEERING.NOTIFY.WATCHERS", "label": "Steering Outcome Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "ReworkRequired",
      "via": 4004,
      "emit": [
        { "route": "APP.CHANGE.REWORK.REQUEST", "label": "Rework Request", "group": "rework_cycle", "order": 1, "complete": { "success": 4009 }, "type": "gate" },
        { "route": "APP.CHANGE.REWORK.LOCAL.BACKUP", "label": "Rework Data Backup", "type": "effect" },
        { "route": "APP.CHANGE.REWORK.EMAIL.REQUESTOR", "label": "Rework Notification Email", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "ReworkRequired",
      "via": 4008,
      "emit": [
        { "route": "APP.CHANGE.REWORK.REQUEST", "label": "Rework Request", "group": "rework_cycle", "order": 1, "complete": { "success": 4009 }, "type": "gate" },
        { "route": "APP.CHANGE.REWORK.LOCAL.BACKUP", "label": "Rework Data Backup", "type": "effect" },
        { "route": "APP.CHANGE.REWORK.EMAIL.REQUESTOR", "label": "Rework Notification Email", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "ReworkRequired",
      "via": 4010,
      "emit": [
        { "route": "APP.CHANGE.REWORK.EXPIRED", "label": "Rework Expired", "type": "effect" },
        { "route": "APP.CHANGE.REWORK.EXPIRED.NOTIFY", "label": "Rework Expiry Notification", "order": 2, "type": "effect" }
      ]
    }
  ],
  "timeouts": [
    { "state": "ReworkRequired", "timeout_minutes": 2, "max_retry": 4, "timeout_event": 4010 }
  ]
}
