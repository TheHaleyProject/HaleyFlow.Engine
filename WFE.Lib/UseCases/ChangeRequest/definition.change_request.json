{
  "name": "ProjectChangeRequest",
  "version": 1,
  "description": "Project change request with impact, cost, schedule and steering review",
  "states": [
    { "name": "RequestLogged", "is_initial": true, "category": "Intake" },
    { "name": "ImpactAssessment", "category": "Assessment" },
    { "name": "CostReview", "category": "Assessment" },
    { "name": "ScheduleReview", "category": "Assessment" },
    { "name": "SteeringDecision", "category": "Approval" },
    { "name": "ReworkRequired", "category": "Resubmission" },
    { "name": "Approved", "is_final": true, "category": "Outcome" },
    { "name": "Cancelled", "is_final": true, "category": "Outcome" }
