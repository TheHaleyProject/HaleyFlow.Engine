  "transitions": [
    { "event": 4000, "from": "RequestLogged", "to": "ImpactAssessment" },
    { "event": 4001, "from": "ImpactAssessment", "to": "CostReview" },
    { "event": 4002, "from": "ImpactAssessment", "to": "Cancelled" },
    { "event": 4003, "from": "CostReview", "to": "ScheduleReview" },
    { "event": 4004, "from": "CostReview", "to": "ReworkRequired" },
    { "event": 4005, "from": "ScheduleReview", "to": "SteeringDecision" },
    { "event": 4006, "from": "ScheduleReview", "to": "ReworkRequired" },
    { "event": 4007, "from": "SteeringDecision", "to": "Approved" },
    { "event": 4008, "from": "SteeringDecision", "to": "ReworkRequired" },
    { "event": 4009, "from": "ReworkRequired", "to": "ImpactAssessment" },
    { "event": 4010, "from": "ReworkRequired", "to": "Cancelled" }
  ]
}
