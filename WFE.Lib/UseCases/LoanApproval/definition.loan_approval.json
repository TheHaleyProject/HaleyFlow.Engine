{
  "name": "LoanApproval",
  "version": 1,
  "description": "Loan approval flow with KYC, credit, risk and manager decision",
  "states": [
    { "name": "ApplicationReceived", "is_initial": true, "category": "Intake" },
    { "name": "KycCheck", "category": "Validation" },
    { "name": "CreditAssessment", "category": "Assessment" },
    { "name": "RiskReview", "category": "Assessment" },
    { "name": "ManagerApproval", "category": "Approval" },
    { "name": "Approved", "is_final": true, "category": "Outcome" },
    { "name": "Rejected", "is_final": true, "category": "Outcome" }
  ],
  "transitions": [
    { "event": 2000, "from": "ApplicationReceived", "to": "KycCheck" },
    { "event": 2001, "from": "KycCheck", "to": "CreditAssessment" },
    { "event": 2002, "from": "KycCheck", "to": "Rejected" },
    { "event": 2003, "from": "CreditAssessment", "to": "RiskReview" },
    { "event": 2004, "from": "CreditAssessment", "to": "Rejected" },
    { "event": 2005, "from": "RiskReview", "to": "ManagerApproval" },
    { "event": 2006, "from": "RiskReview", "to": "Rejected" },
    { "event": 2007, "from": "ManagerApproval", "to": "Approved" },
    { "event": 2008, "from": "ManagerApproval", "to": "Rejected" },
    { "event": 2009, "from": "ManagerApproval", "to": "ManagerApproval" }
  ]
}
