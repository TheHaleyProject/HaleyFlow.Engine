{
  "policy_name": "loanapproval.policy",
  "defName": "LoanApproval",
  "params": [
    {
      "code": "PARAMS.LOAN.MANAGER.APPROVAL",
      "data": {
        "approval": {
          "rule": "any",
          "selector": {
            "mode": "role",
            "value": "loan_manager"
          }
        }
      }
    }
  ],
  "rules": [
    {
      "state": "KycCheck",
      "emit": [
        {
          "route": "APP.LOAN.KYC.CHECK",
          "label": "KYC Check",
          "blocking": true,
          "group": "kyc_decision",
          "order": 1,
          "complete": { "success": 2001, "failure": 2002 }
        },
        {
          "route": "APP.LOAN.KYC.AUDIT.LOG",
          "label": "KYC Audit Log",
          "blocking": false
        },
        {
          "route": "APP.LOAN.KYC.NOTIFY.APPLICANT",
          "label": "KYC Result Notification",
          "blocking": false,
          "order": 2
        }
      ]
    },
    {
      "state": "CreditAssessment",
      "emit": [
        {
          "route": "APP.LOAN.CREDIT.CHECK",
          "label": "Credit Assessment",
          "blocking": true,
          "group": "credit_decision",
          "order": 1,
          "complete": { "success": 2003, "failure": 2004 }
        },
        {
          "route": "APP.LOAN.CREDIT.LOCAL.BACKUP",
          "label": "Credit Snapshot Backup",
          "blocking": false
        },
        {
          "route": "APP.LOAN.CREDIT.RISK.FEED",
          "label": "Risk Feed Update",
          "blocking": false,
          "order": 2
        }
      ]
    },
    {
      "state": "RiskReview",
      "emit": [
        {
          "route": "APP.LOAN.RISK.CHECK",
          "label": "Risk Review",
          "blocking": true,
          "group": "risk_decision",
          "order": 1,
          "complete": { "success": 2005, "failure": 2006 }
        },
        {
          "route": "APP.LOAN.RISK.AUDIT.LOG",
          "label": "Risk Audit Log",
          "blocking": false
        },
        {
          "route": "APP.LOAN.RISK.NOTIFY.ANALYST",
          "label": "Risk Analyst Notification",
          "blocking": false,
          "order": 2
        }
      ]
    },
    {
      "state": "ManagerApproval",
      "params": [ "PARAMS.LOAN.MANAGER.APPROVAL" ],
      "emit": [
        {
          "route": "APP.LOAN.MANAGER.DECISION",
          "label": "Manager Approval Decision",
          "blocking": true,
          "group": "manager_decision",
          "order": 1,
          "complete": { "success": 2007, "failure": 2008 }
        },
        {
          "route": "APP.LOAN.MANAGER.DOC.ARCHIVE",
          "label": "Manager Approval Archive",
          "blocking": true,
          "order": 2
        },
        {
          "route": "APP.LOAN.MANAGER.NOTIFY.APPLICANT",
          "label": "Manager Decision Notification",
          "blocking": false,
          "order": 2
        }
      ]
    },
    {
      "state": "ManagerApproval",
      "via": 2009,
      "emit": [
        {
          "route": "APP.LOAN.MANAGER.REMINDER",
          "label": "Manager Approval Reminder",
          "blocking": false
        },
        {
          "route": "APP.LOAN.MANAGER.REMINDER.EMAIL",
          "label": "Reminder Email Dispatch",
          "blocking": false,
          "order": 2
        }
      ]
    }
  ],
  "timeouts": [
    { "state": "ManagerApproval", "timeout": "P1D", "timeout_event": 2009, "timeout_mode": "repeat" }
  ]
}
