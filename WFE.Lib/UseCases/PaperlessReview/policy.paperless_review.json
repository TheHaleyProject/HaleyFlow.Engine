{
  "policy_name": "paperlessreview.policy",
  "defName": "PaperlessReview",
  "params": [
    { "code": "PARAMS.REVIEW.GRADE", "data": { "grading": { "scale": "A-F", "passGrades": [ "A", "B", "C" ] } } }
  ],
  "rules": [
    {
      "state": "ComplianceReview",
      "emit": [
        { "route": "APP.REVIEW.COMPLIANCE", "label": "Compliance Review", "group": "compliance_decision", "order": 1, "complete": { "success": 3001, "failure": 3002 }, "type": "gate" },
        { "route": "APP.REVIEW.COMPLIANCE.AUDIT.LOG", "label": "Compliance Audit Log", "type": "effect" },
        { "route": "APP.REVIEW.COMPLIANCE.NOTIFY.TEAM", "label": "Compliance Team Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "StructuralReview",
      "emit": [
        { "route": "APP.REVIEW.STRUCTURAL", "label": "Structural Review", "group": "structural_decision", "order": 1, "complete": { "success": 3003, "failure": 3004 }, "type": "gate" },
        { "route": "APP.REVIEW.STRUCTURAL.LOCAL.BACKUP", "label": "Structural Snapshot Backup", "type": "effect" },
        { "route": "APP.REVIEW.STRUCTURAL.NOTIFY.TEAM", "label": "Structural Team Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "MEPReview",
      "emit": [
        { "route": "APP.REVIEW.MEP", "label": "MEP Review", "group": "mep_decision", "order": 1, "complete": { "success": 3005, "failure": 3006 }, "type": "gate" },
        { "route": "APP.REVIEW.MEP.LOCAL.BACKUP", "label": "MEP Snapshot Backup", "type": "effect" },
        { "route": "APP.REVIEW.MEP.NOTIFY.TEAM", "label": "MEP Team Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "ConsolidateComments",
      "emit": [
        { "route": "APP.REVIEW.COMMENTS.CONSOLIDATE", "label": "Consolidate Comments", "group": "comments_publish", "order": 1, "complete": { "success": 3007 }, "type": "gate" },
        { "route": "APP.REVIEW.COMMENTS.PUBLISH", "label": "Publish Consolidated Comments", "order": 2, "type": "gate" },
        { "route": "APP.REVIEW.COMMENTS.NOTIFY.AUTHOR", "label": "Comments Published Notification", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "Grading",
      "params": [ "PARAMS.REVIEW.GRADE" ],
      "emit": [
        { "route": "APP.REVIEW.GRADING", "label": "Review Grading", "group": "grading_decision", "order": 1, "complete": { "success": 3008, "failure": 3009 }, "type": "gate" },
        { "route": "APP.REVIEW.GRADING.AUDIT.LOG", "label": "Grading Audit Log", "type": "effect" },
        { "route": "APP.REVIEW.GRADING.EMAIL.REPORT", "label": "Grading Report Email", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "RevisionRequired",
      "via": 3009,
      "emit": [
        { "route": "APP.REVIEW.REVISION.NOTIFY", "label": "Revision Request Notification", "group": "revision_cycle", "order": 1, "complete": { "success": 3010 }, "type": "gate" },
        { "route": "APP.REVIEW.REVISION.EMAIL.CONSULTANT", "label": "Consultant Revision Email", "order": 2, "type": "effect" }
      ]
    },
    {
      "state": "Resubmitted",
      "emit": [
        { "route": "APP.REVIEW.RESUBMISSION.RECEIVED", "label": "Resubmission Received", "group": "resubmission_cycle", "order": 1, "complete": { "success": 3011 }, "type": "gate" },
        { "route": "APP.REVIEW.RESUBMISSION.AUDIT.LOG", "label": "Resubmission Audit Log", "type": "effect" }
      ]
    },
    {
      "state": "RevisionRequired",
      "via": 3012,
      "emit": [
        { "route": "APP.REVIEW.REVISION.EXPIRED", "label": "Revision Window Expired", "type": "effect" },
        { "route": "APP.REVIEW.REVISION.EXPIRED.EMAIL", "label": "Revision Expiry Email", "order": 2, "type": "effect" }
      ]
    }
  ],
  "timeouts": [
    { "state": "RevisionRequired", "timeout": "P14D", "timeout_event": 3012 }
  ]
}
