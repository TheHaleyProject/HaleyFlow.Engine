			</index>
			<fk name="fk_transition_log_instance" to_schema="lcstate" to_table="instance" >
				<fk_column name="instance_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 2000  
]]></options>
		</table>
		<table name="policy" prior="polic" >
