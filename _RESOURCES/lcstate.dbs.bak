			</fk>
			<fk name="fk_state_category" to_schema="lcstate" to_table="category" >
				<fk_column name="category" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 2014 
]]></options>
		</table>
		<table name="timeouts" prior="policy_timeouts" >
			<comment><![CDATA[Timeout rules per policy and state, including mode and event to emit on expiry.]]></comment>
			<column name="policy_id" type="INT" mandatory="y" >
				<comment><![CDATA[Policy identifier associated with this record.]]></comment>
			</column>
			<column name="state_name" type="VARCHAR" length="200" mandatory="y" >
				<comment><![CDATA[State name this rule targets.]]></comment>
			</column>
			<column name="duration" prior="timeout_minutes" type="INT" mandatory="y" >
				<comment><![CDATA[Timeout duration value interpreted by engine timeout semantics.]]></comment>
			</column>
			<column name="mode" prior="timeout_mode" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Timeout mode: 0=Once, 1=Repeat.]]></comment>
			</column>
			<column name="event_code" prior="timeout_event_code" type="INT" >
				<comment><![CDATA[Event code emitted when timeout is reached.]]></comment>
			</column>
			<column name="max_retry" type="INT" />
			<index name="pk_timeouts" unique="PRIMARY_KEY" >
				<column name="policy_id" />
				<column name="state_name" />
			</index>
			<fk name="fk_timeouts_policy" to_schema="lcstate" to_table="policy" >
				<fk_column name="policy_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="transition" prior="transi" >
			<comment><![CDATA[Allowed transition graph edges per definition version.]]></comment>
			<column name="id" type="INT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="from_state" type="INT" mandatory="y" >
				<comment><![CDATA[Source state identifier.]]></comment>
			</column>
			<column name="to_state" type="INT" mandatory="y" >
				<comment><![CDATA[Target state identifier.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="def_version" prior="def" type="INT" mandatory="y" >
				<comment><![CDATA[Definition version identifier (FK to def_version.id).]]></comment>
			</column>
			<column name="event" type="INT" mandatory="y" >
				<comment><![CDATA[Event identifier that triggered this transition.]]></comment>
			</column>
			<index name="pk_transition" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_transition" unique="UNIQUE_KEY" >
				<column name="def_version" />
				<column name="from_state" />
				<column name="to_state" />
				<column name="event" />
			</index>
			<index name="fk_transition_state" unique="NORMAL" >
				<column name="from_state" />
			</index>
			<index name="fk_transition_state_0" unique="NORMAL" >
				<column name="to_state" />
			</index>
			<index name="fk_transition_events" unique="NORMAL" >
				<column name="event" />
			</index>
			<fk name="fk_transition_state" to_schema="lcstate" to_table="state" >
				<fk_column name="from_state" pk="id" />
			</fk>
			<fk name="fk_transition_state_0" to_schema="lcstate" to_table="state" >
				<fk_column name="to_state" pk="id" />
			</fk>
			<fk name="fk_transition_def_version" to_schema="lcstate" to_table="def_version" >
				<fk_column name="def_version" pk="id" />
			</fk>
			<fk name="fk_transition_events" to_schema="lcstate" to_table="events" >
				<fk_column name="event" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 1988  
]]></options>
		</table>
	</schema>
