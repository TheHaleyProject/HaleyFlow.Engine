			</index>
			<fk name="fk_consumer_beat_environment" to_schema="lcstate" to_table="environment" >
				<fk_column name="env" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 1995  
]]></options>
		</table>
		<table name="def_policies" prior="definition_policies" >
			<comment><![CDATA[Associative mapping between workflow definitions and policy records.]]></comment>
			<column name="definition" type="INT" mandatory="y" >
				<comment><![CDATA[Workflow definition identifier (FK to definition.id).]]></comment>
			</column>
			<column name="policy" type="INT" mandatory="y" >
				<comment><![CDATA[Policy identifier (FK to policy.id).]]></comment>
			</column>
			<column name="modified" prior="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<index name="pk_def_policies" unique="PRIMARY_KEY" >
