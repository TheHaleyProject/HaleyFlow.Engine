				<identity><![CDATA[GENERATED  ALWAYS AS (lcase(trim(`display_name`)))]]></identity>
				<comment><![CDATA[System-generated normalized category key (lowercase trimmed display_name).]]></comment>
			</column>
			<index name="pk_category" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
