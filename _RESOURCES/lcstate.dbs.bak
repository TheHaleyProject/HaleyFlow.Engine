			<column name="name" type="VARCHAR" length="140" >
				<identity><![CDATA[GENERATED  ALWAYS AS (lcase(trim(`display_name`)))]]></identity>
				<comment><![CDATA[System-generated normalized activity key (lowercase trimmed display_name).]]></comment>
			</column>
			<index name="pk_activity" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 1998  
]]></options>
		</table>
		<table name="activity_status" prior="runtime_state" >
