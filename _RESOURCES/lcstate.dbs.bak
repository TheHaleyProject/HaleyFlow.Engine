				<comment><![CDATA[State identifier in current workflow context.]]></comment>
			</column>
			<column name="actor_id" type="VARCHAR" length="60" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Actor identifier for runtime activity tracking.]]></comment>
			</column>
			<column name="status" prior="runtime_state" type="INT" mandatory="y" >
				<comment><![CDATA[Runtime activity status identifier (FK to activity_status.id).]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="modified" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="frozen" type="BIT" mandatory="y" >
