 AUTO_INCREMENT 1999  
]]></options>
		</table>
		<table name="consumer" prior="consumer_beat" >
			<comment><![CDATA[Registered consumer applications with environment binding and heartbeat for liveness detection.]]></comment>
			<column name="id" type="INT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="env" prior="env_id" type="INT" mandatory="y" >
				<comment><![CDATA[Environment identifier (FK to environment.id).]]></comment>
			</column>
			<column name="consumer_guid" prior="consumer" type="VARCHAR" length="38" mandatory="y" >
				<comment><![CDATA[Consumer instance GUID used for identity and heartbeat tracking.]]></comment>
			</column>
			<column name="last_beat" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[Latest heartbeat timestamp reported by consumer.]]></comment>
			</column>
			<index name="pk_consumer" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_consumer_beat" unique="UNIQUE_KEY" >
				<column name="env" />
