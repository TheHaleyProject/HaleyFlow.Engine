			</column>
			<index name="pk_activity_status" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 1998  
]]></options>
		</table>
		<table name="category" prior="tbl" >
