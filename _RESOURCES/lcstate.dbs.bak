<?xml version="1.0" encoding="UTF-8" ?>
<project name="lifecycle_state" database="MariaDb" id="19f578f4-fff8-4e61-ac61-4d42ca9c2334" >
	<schema name="lcstate" >
		<table name="ack" prior="ac" >
			<comment><![CDATA[Master acknowledgement envelope created by the engine and used for cross-system correlation.]]></comment>
			<column name="guid" type="CHAR" length="36" mandatory="y" >
				<defo><![CDATA[uuid()]]></defo>
				<comment><![CDATA[Stable GUID used for external correlation.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<index name="pk_ack" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_ack" unique="UNIQUE_KEY" >
				<column name="guid" />
			</index>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 2000  
]]></options>
		</table>
		<table name="ack_consumer" prior="ack" >
			<comment><![CDATA[Per-consumer delivery state for each acknowledgement, including retry scheduling and processing outcome.]]></comment>
			<column name="consumer" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Consumer identifier.]]></comment>
			</column>
			<column name="ack_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Acknowledgement identifier (FK to ack.id).]]></comment>
			</column>
			<column name="status" prior="ack_status" type="INT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Acknowledgement state: 1=Pending, 2=Delivered, 3=Processed, 4=Failed 5=Cancelled]]></comment>
			</column>
			<column name="max_trigger" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
			</column>
			<column name="last_trigger" prior="last_retry" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[Most recent dispatch trigger timestamp.]]></comment>
			</column>
			<column name="trigger_count" prior="retry_count" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Number of dispatch attempts performed so far.]]></comment>
			</column>
			<column name="next_due" type="DATETIME" >
				<comment><![CDATA[Next scheduled timestamp for retry/dispatch. From C#, this is set as DateTime.UtcNow.. so we need to consider this time is in UTC time.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="modified" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<column_options><![CDATA[ON UPDATE CURRENT_TIMESTAMP]]></column_options>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="message" type="TEXT" />
			<index name="idx_ack_consumer" unique="NORMAL" >
				<column name="next_due" />
				<column name="status" />
			</index>
			<index name="idx_ack_consumer_0" unique="NORMAL" >
				<column name="consumer" />
				<column name="next_due" />
				<column name="status" />
			</index>
			<index name="pk_ack_consumer" unique="PRIMARY_KEY" >
				<column name="ack_id" />
				<column name="consumer" />
			</index>
			<fk name="fk_ack_consumer_ack" to_schema="lcstate" to_table="ack" >
				<fk_column name="ack_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 2000  
]]></options>
		</table>
		<table name="activity" prior="activ" >
			<comment><![CDATA[Catalog of business activities tracked by consumers outside core state transitions.]]></comment>
			<column name="display_name" type="VARCHAR" length="140" mandatory="y" >
