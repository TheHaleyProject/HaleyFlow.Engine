		<table name="hook" prior="hooks" >
			<comment><![CDATA[Hook work items emitted by policy on lifecycle edges and routed to consumers.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="state_id" type="INT" mandatory="y" >
				<comment><![CDATA[State identifier in current workflow context.]]></comment>
			</column>
			<column name="via_event" type="INT" mandatory="y" >
				<comment><![CDATA[Event identifier that caused this hook emission.]]></comment>
			</column>
			<column name="on_entry" type="BIT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Hook phase flag: 1=OnEntry, 0=OnExit.]]></comment>
			</column>
			<column name="created" prior="creted" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="route_id" prior="route" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Route identifier to invoke for this hook (FK to hook_route.id).]]></comment>
			</column>
			<column name="type" prior="blocking" type="BIT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Decides if a hook is bloking or not
1 - Gate : requires successful hook completion before progression.
0 - Effect : if fails, nothing happens.]]></comment>
			</column>
			<column name="group_id" prior="group" type="BIGINT" >
				<comment><![CDATA[Optional grouping identifier for related hooks (FK to hook_group.id).]]></comment>
			</column>
			<column name="order_seq" type="SMALLINT" length="6" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Dispatch order sequence; lower numbers are dispatched first.]]></comment>
			</column>
			<column name="ack_mode" type="TINYINT" length="4" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[ACK aggregation mode: 0=AllConsumersMustProcess, 1=AnyConsumerMaySatisfy.]]></comment>
			</column>
			<column name="instance_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Workflow instance identifier (FK to instance.id).]]></comment>
			</column>
			<index name="pk_hook" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_hooks" unique="UNIQUE_KEY" >
				<column name="instance_id" />
				<column name="state_id" />
				<column name="via_event" />
				<column name="on_entry" />
				<column name="route_id" />
			</index>
			<index name="fk_hook_hook_route" unique="NORMAL" >
				<column name="route_id" />
			</index>
			<index name="fk_hook_hook_group" unique="NORMAL" >
				<column name="group_id" />
			</index>
			<fk name="fk_hooks_instance" to_schema="lcstate" to_table="instance" >
				<fk_column name="instance_id" pk="id" />
			</fk>
			<fk name="fk_hook_hook_route" to_schema="lcstate" to_table="hook_route" >
				<fk_column name="route_id" pk="id" />
			</fk>
			<fk name="fk_hook_hook_group" to_schema="lcstate" to_table="hook_group" >
				<fk_column name="group_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 2000  
]]></options>
		</table>
		<table name="hook_ack" prior="hook_ck" >
			<comment><![CDATA[One-to-one mapping between hook lifecycle entries and acknowledgement envelopes.]]></comment>
			<column name="ack_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Acknowledgement identifier (FK to ack.id).]]></comment>
			</column>
			<column name="hook_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Hook lifecycle identifier (FK to hook_lc.id).]]></comment>
			</column>
			<index name="pk_hook_ack" unique="PRIMARY_KEY" >
				<column name="hook_id" />
			</index>
			<index name="unq_hook_ack" unique="UNIQUE_KEY" >
				<column name="ack_id" />
			</index>
			<fk name="fk_hook_ack_ack" to_schema="lcstate" to_table="ack" >
				<fk_column name="ack_id" pk="id" />
			</fk>
			<fk name="fk_hook_ack_hook_lc" to_schema="lcstate" to_table="hook_lc" >
				<fk_column name="hook_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="hook_group" prior="hook_g" >
			<comment><![CDATA[Named grouping of hook routes for orchestration and operational organization.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="name" type="VARCHAR" length="140" mandatory="y" >
				<comment><![CDATA[Unique hook group name used to classify related routes.]]></comment>
			</column>
			<index name="pk_hook_group" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_hook_group" unique="UNIQUE_KEY" >
				<column name="name" />
			</index>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="hook_lc" prior="hook_" >
			<comment><![CDATA[Link between hook entries and lifecycle records, including dispatch marker.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="dispatched" type="BIT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Dispatch marker: 0=NotDispatched, 1=Dispatched.]]></comment>
			</column>
			<column name="hook_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Hook identifier.]]></comment>
			</column>
			<column name="lc_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Lifecycle identifier (FK to lifecycle.id).]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="status" type="TINYINT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[0=Pending, 1=Dispatched, 2=Skipped]]></comment>
			</column>
			<index name="pk_hook_lc" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_hook_lc" unique="UNIQUE_KEY" >
				<column name="hook_id" />
				<column name="lc_id" />
			</index>
			<index name="fk_hook_lc_lifecycle" unique="NORMAL" >
				<column name="lc_id" />
			</index>
			<fk name="fk_hook_lc_hook" to_schema="lcstate" to_table="hook" >
				<fk_column name="hook_id" pk="id" />
			</fk>
			<fk name="fk_hook_lc_lifecycle" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="lc_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="hook_route" prior="route" >
			<comment><![CDATA[Canonical route names targeted by hook dispatching.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="name" type="VARCHAR" length="240" mandatory="y" >
				<comment><![CDATA[Unique hook route name invoked by consumers.]]></comment>
			</column>
			<column name="label" type="VARCHAR" length="120" mandatory="y" />
			<index name="pk_hook_route" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_route" unique="UNIQUE_KEY" >
				<column name="name" />
				<column name="label" />
			</index>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="instance" prior="insta" >
			<comment><![CDATA[Workflow instance aggregate for one business entity, including immutable metadata and mutable runtime context.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="def_version" type="INT" mandatory="y" >
				<comment><![CDATA[Definition version identifier (FK to def_version.id).]]></comment>
			</column>
			<column name="current_state" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Current state identifier for this instance.]]></comment>
			</column>
			<column name="last_event" type="INT" >
				<comment><![CDATA[Most recently applied event identifier.]]></comment>
			</column>
			<column name="guid" type="CHAR" length="36" mandatory="y" >
				<defo><![CDATA[uuid()]]></defo>
				<comment><![CDATA[Stable GUID used for external correlation.]]></comment>
			</column>
			<column name="entity_id" prior="entity_ref" type="VARCHAR" length="36" mandatory="y" >
				<comment><![CDATA[External business entity identifier (for example submission or application id).]]></comment>
			</column>
			<column name="def_id" type="INT" mandatory="y" >
				<comment><![CDATA[Workflow definition identifier.]]></comment>
			</column>
			<column name="policy_id" type="INT" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Policy identifier associated with this record.]]></comment>
			</column>
			<column name="flags" type="INT" mandatory="y" unsigned="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Instance flags bitmask: 1=Active, 2=Suspended, 4=Completed, 8=Failed, 16=Archived.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="modified" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<column_options><![CDATA[ON UPDATE CURRENT_TIMESTAMP]]></column_options>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="message" type="TEXT" >
				<comment><![CDATA[Operational note describing current state or failure context.]]></comment>
			</column>
			<column name="metadata" type="LONGTEXT" >
				<comment><![CDATA[Immutable initiation metadata (example: {"source":"backfill"}).]]></comment>
			</column>
			<column name="context" type="LONGTEXT" >
				<comment><![CDATA[Mutable runtime context bag updated by workflow processing.]]></comment>
			</column>
			<index name="pk_instance" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_instance" unique="UNIQUE_KEY" >
				<column name="guid" />
			</index>
			<index name="fk_instance_state" unique="NORMAL" >
				<column name="current_state" />
			</index>
			<index name="fk_instance_events" unique="NORMAL" >
				<column name="last_event" />
			</index>
			<index name="fk_instance_def_version" unique="NORMAL" >
				<column name="def_version" />
			</index>
			<index name="idx_instance" unique="NORMAL" >
				<column name="entity_id" />
			</index>
			<index name="unq_instance_0" unique="UNIQUE_KEY" >
				<column name="def_id" />
				<column name="entity_id" />
			</index>
			<fk name="fk_instance_def_version" to_schema="lcstate" to_table="def_version" >
				<fk_column name="def_version" pk="id" />
			</fk>
			<fk name="fk_instance_definition" to_schema="lcstate" to_table="definition" >
				<fk_column name="def_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB
 AUTO_INCREMENT 1857  
]]></options>
		</table>
		<table name="lc_ack" prior="lc_a" >
			<comment><![CDATA[Mapping between lifecycle transitions and acknowledgement envelopes for transition delivery.]]></comment>
			<column name="ack_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Acknowledgement identifier (FK to ack.id).]]></comment>
			</column>
			<column name="lc_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Lifecycle identifier (FK to lifecycle.id).]]></comment>
			</column>
			<index name="pk_lc_ack" unique="PRIMARY_KEY" >
				<column name="lc_id" />
			</index>
			<index name="idx_lc_ack" unique="UNIQUE_KEY" >
				<column name="ack_id" />
			</index>
			<fk name="fk_lc_ack_lifecycle" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="lc_id" pk="id" />
			</fk>
			<fk name="fk_lc_ack_ack" to_schema="lcstate" to_table="ack" >
				<fk_column name="ack_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="lc_data" prior="macro_data" >
			<comment><![CDATA[Supplemental actor and payload details captured for lifecycle transitions.]]></comment>
			<column name="lc_id" prior="lc_log" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Lifecycle identifier (FK to lifecycle.id).]]></comment>
			</column>
			<column name="actor" type="VARCHAR" length="60" >
				<comment><![CDATA[Actor identity (user/system/service) for this operation.]]></comment>
			</column>
			<column name="payload" prior="metadata" type="LONGTEXT" >
				<comment><![CDATA[Input payload captured for traceability and replay diagnostics.]]></comment>
			</column>
			<index name="pk_lc_data" unique="PRIMARY_KEY" >
				<column name="lc_id" />
			</index>
			<fk name="fk_transition_data_transition_log" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="lc_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="lc_next" prior="lc_nex" >
			<column name="id" type="BIGINT" mandatory="y" />
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[CURRENT_TIMESTAMP]]></defo>
			</column>
			<column name="next" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[suggested Code . If 0, then it means, we have completed the hooks, but noone of them have the complete codes.. even the transition itself doens' thave the code.. so, we just need to inform the consumer to complete this.. and consumer should know what to transition next.. (its a case of hard coded transitions)]]></comment>
			</column>
			<column name="ack_id" type="BIGINT" >
				<comment><![CDATA[acknolwedgement id associated which triggered this .. may be a hook triggered this.. or the transition itself triggered this.. sometimes. transsition triggered this, (created this) but the complete codes comes from hooks.. so, we just captured after which ack we created this? or it can even tbe null]]></comment>
			</column>
			<column name="dispatched" type="BIT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[did we actually create a acknowledgemetn? our job is only to create the acknowledgmeent.. then the existing infrastructure takes care of this.. like monitor and events..]]></comment>
			</column>
			<index name="pk_lc_next" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<fk name="fk_lc_next_lifecycle" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="lc_timeout" prior="timeout" >
			<comment><![CDATA[Marker table for lifecycle entries generated by timeout processing.]]></comment>
			<column name="lc_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[Lifecycle identifier (FK to lifecycle.id).]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="trigger_count" prior="notice_count" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
			</column>
			<column name="last_trigger" prior="last_noticed_at" type="DATETIME" />
			<column name="next_due" prior="next_due_at" type="DATETIME" />
			<column name="max_retry" type="INT" >
				<comment><![CDATA[if null, then take the default max_retry fo engine.. else, use max retry from the policy]]></comment>
			</column>
			<index name="pk_lc_timeout" unique="PRIMARY_KEY" >
				<column name="lc_id" />
			</index>
			<fk name="fk_timeout_lifecycle" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="lc_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="lcn_ack" prior="lcn_" >
			<comment><![CDATA[acknowledgmeent for lc next.]]></comment>
			<column name="ack_id" type="BIGINT" mandatory="y" />
			<column name="lc_id" type="BIGINT" mandatory="y" >
				<comment><![CDATA[same lc id is reused..]]></comment>
			</column>
			<index name="pk_lcn_ack" unique="PRIMARY_KEY" >
				<column name="lc_id" />
			</index>
			<fk name="fk_lcn_ack_ack" to_schema="lcstate" to_table="ack" >
				<fk_column name="ack_id" pk="id" />
			</fk>
			<fk name="fk_lcn_ack_lifecycle" to_schema="lcstate" to_table="lifecycle" >
				<fk_column name="lc_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="lifecycle" prior="lifecycle_log" >
