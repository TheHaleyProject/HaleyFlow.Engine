				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="display_name" type="VARCHAR" length="200" mandatory="y" >
				<comment><![CDATA[Human-readable display name.]]></comment>
			</column>
			<column name="name" type="VARCHAR" length="200" >
				<identity><![CDATA[GENERATED  ALWAYS AS (lcase(trim(`display_name`)))]]></identity>
				<comment><![CDATA[System-generated normalized state key (lowercase trimmed display_name).]]></comment>
			</column>
			<column name="category" type="INT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[State category identifier (FK to category.id).]]></comment>
			</column>
			<column name="flags" type="INT" mandatory="y" unsigned="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[State flags bitmask: 1=Initial, 2=Final, 4=System, 8=Error.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="def_version" type="INT" mandatory="y" >
				<comment><![CDATA[Definition version identifier (FK to def_version.id).]]></comment>
			</column>
